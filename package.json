{
  "name": "ballistics-frontend",
  "version": "1.0.0",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": [
      "src/test/js"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "coverageDirectory": "target/js-coverage",
    "collectCoverageFrom": [
      "src/main/resources/static/ballistics.js"
    ]
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "vite": "^6.3.4"
  }
}
