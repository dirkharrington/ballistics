{
  "name": "ballistics-frontend",
  "version": "1.0.0",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": ["src/test/js"],
    "testMatch": ["**/*.test.js"],
    "coverageDirectory": "target/js-coverage",
    "collectCoverageFrom": ["src/main/resources/static/ballistics.js"],
    "transform": { "^.+\\.js$": "babel-jest" },
    "moduleNameMapper": {
      "^chart\\.js$": "<rootDir>/src/test/js/__mocks__/chart.js",
      "^virtual:bullet-catalog$": "<rootDir>/src/test/js/__mocks__/bullet-catalog.js"
    },
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "js-yaml": "^4.1.0",
    "vite": "^6.3.4"
  }
}
